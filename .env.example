# Copy this file to `.env` (which is git-ignored) and fill in your values.
# When all three JIRA_* variables are set, the demo CLI runs in REAL mode
# against your Jira Cloud instance; otherwise it uses built-in mock data.

# Your Jira Cloud base URL, e.g. https://your-domain.atlassian.net
JIRA_BASE_URL="https://your-domain.atlassian.net"

# The email address associated with your Atlassian account.
JIRA_USER_EMAIL="you@example.com"

# A Jira API token. Create one at:
# https://id.atlassian.com/manage-profile/security/api-tokens
# NEVER commit your real token.
JIRA_API_TOKEN="your-api-token-here"
